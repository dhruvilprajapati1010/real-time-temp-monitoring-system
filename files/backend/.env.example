# .env — Copy this file to backend/.env and fill in your real values.
# NEVER commit the real .env to version control.

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Copy the connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=iot_temp_monitor

# ── ThingSpeak ─────────────────────────────────────────────────────────────────
# Get from: ThingSpeak → Channels → Your Channel → API Keys tab
THINGSPEAK_CHANNEL_ID=YOUR_CHANNEL_ID
THINGSPEAK_READ_API_KEY=YOUR_READ_API_KEY

# ── Twilio ─────────────────────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+14155552671   # Your Twilio phone number
ALERT_TO_NUMBER=+919876543210     # Your personal number (must be verified on trial)

# ── Alert Thresholds ───────────────────────────────────────────────────────────
TEMP_HIGH_THRESHOLD=40.0      # °C — trigger HIGH alert above this
TEMP_LOW_THRESHOLD=0.0        # °C — trigger LOW alert below this
RAPID_RISE_DELTA=5.0          # °C — trigger RAPID_RISE if temp jumps this much...
RAPID_RISE_WINDOW=5           # ...within this many minutes
ALERT_COOLDOWN_MINUTES=15     # Suppress duplicate alerts for this long

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development          # Change to 'production' for deployment
SECRET_KEY=change-me-to-a-long-random-string
PORT=5000

# ── Polling ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30       # How often to fetch from ThingSpeak
